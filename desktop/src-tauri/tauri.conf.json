{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Okto",
  "version": "0.4.3",
  "identifier": "com.okto.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Okto",
        "width": 1280,
        "height": 800,
        "maximized": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI1M0Y1M0MzRDNGNzU0QUYKUldTdlZQZlR3MU0vdGZMdklJNU8yYXZnWUpHNVV5Y0F2TmQ1Y29aYkRjazNDSlBJNk9YOFBVNkUK",
      "endpoints": [
        "https://github.com/georgebradford0/okto/releases/download/desktop-latest/latest.json"
      ]
    }
  }
}
