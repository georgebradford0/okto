# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Workspace filename. Without this, CocoaPods derives it from the
# `okto.xcodeproj` filename, which works today but the explicit pin keeps
# it stable if someone renames the xcodeproj or adds a sibling. Also
# matches the path CI expects (.github/workflows/ios.yml).
workspace 'okto'

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'okto' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Monorepo (npm workspaces): the hermes-engine podspec bakes an ABSOLUTE
    # HERMES_CLI_PATH into the Pods xcconfig by resolving the (hoisted)
    # hermes-compiler at pod-install time. That resolved path differs between
    # machines/CI (root vs mobile node_modules), so the release "Bundle React
    # Native code and images" phase fails with "hermesc: No such file". Pin it
    # to a $(PODS_ROOT)-relative path that always points at the workspace-root
    # node_modules (Pods -> ios -> mobile -> repo root).
    hermesc = '$(PODS_ROOT)/../../../node_modules/hermes-compiler/hermesc/osx-bin/hermesc'
    Dir.glob(File.join(installer.sandbox.root.to_s, 'Target Support Files', 'Pods-*', '*.xcconfig')).each do |f|
      text = File.read(f)
      next unless text.include?('HERMES_CLI_PATH')
      File.write(f, text.gsub(/^HERMES_CLI_PATH = .*$/, "HERMES_CLI_PATH = #{hermesc}"))
    end
  end
end
